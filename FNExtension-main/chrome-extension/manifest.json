{
  "manifest_version": 3,
  "name": "My Chrome Extension",
  "version": "1.0.0",
  "description": "A basic Chrome extension",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.fonbet.ru/*", "*://*.fonbet.com/*"],
      "js": ["content.js"]
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://live.kawarji.com/",
    "*://*.fonbet.ru/*",
    "*://*.fonbet.com/*",
    "*://*.fupa.net/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["log.html", "log.js", "sounds/*.mp3", "german-scraper.js", "german-scraper.css"],
      "matches": ["<all_urls>"]
    }
  ]
}